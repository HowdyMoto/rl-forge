<mujoco model="cartpole">
  <compiler angle="radian" />
  <option gravity="0 -9.8 0" />
  <default>
    <geom friction="0.0" />
    <joint damping="0.0" />
  </default>
  <custom>
    <numeric name="gravityScale" data="1" />
    <text name="forwardBody" data="torso" />
    <numeric name="groundY" data="-0.05" />
    <numeric name="groundFriction" data="0" />
    <numeric name="groundRestitution" data="0" />
    <text name="defaultReward" data="{&quot;forwardVelWeight&quot;:0,&quot;aliveBonusWeight&quot;:1,&quot;ctrlCostWeight&quot;:0,&quot;terminationPenalty&quot;:1,&quot;cartPositionLimit&quot;:2.4,&quot;poleAngleLimit&quot;:0.4188790204786391,&quot;anglePenaltyWeight&quot;:0.5,&quot;positionPenaltyWeight&quot;:0.1}" />
  </custom>
  <worldbody>
    <geom name="ground" type="plane" pos="0 -0.05 0" size="50 1 1" friction="0 0 0" rgba="0.3 0.3 0.3 1" />
    <body name="anchor" pos="0 0.15 0" rl-forge:fixed="true">
      <geom name="anchor" type="box" size="0.005 0.005 0.05" mass="1" friction="0" />
      <body name="torso" pos="0 0.15 0">
        <joint name="rail" type="slide" axis="1 0 0" limited="true" range="-2.4 2.4" pos="0 0 0" damping="0" rl-forge:maxVelocity="20" rl-forge:anchorA="0 0" />
        <geom name="torso" type="box" size="0.25 0.075 0.05" mass="1" friction="0" rl-forge:minY="-10" rl-forge:maxAngle="100" />
        <body name="pole" pos="0 0.725 0">
          <joint name="hinge" type="hinge" axis="0 0 1" limited="true" range="-3.14159 3.14159" pos="0 -0.5 0" damping="0" rl-forge:maxVelocity="20" rl-forge:anchorA="0 0.075" />
          <geom name="pole" type="capsule" size="0.025" fromto="0 -0.45 0 0 0.45 0" mass="0.1" friction="0" />
        </body>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor name="rail_motor" joint="rail" gear="10" ctrllimited="true" ctrlrange="-1 1" />
  </actuator>
</mujoco>
